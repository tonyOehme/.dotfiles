[user]
	name = Tony Andy Oehme
	email = tony-andy.oehme@adesso.de
[init]
	defaultBranch = main
[core]
	editor = nvim
    pager = cat
	excludesfile = ~/.gitignore_global
    whitespace = -trailing-space
[pull]
	rebase = false
[diff]
    renames = true
    wordRegex = .
    submodule = log
    mnemonicPrefix = true
	colorMoved = true
[color]
	ui = auto
[status]
    submoduleSummary = true
    showUntrackedFiles = all
[merge]
	conflictstyle = diff3
[grep]
	linenumber = true
    break = true
    heading = true
    extendedRegexp = true
