[submodule ".scripts"]
	path = .scripts
	url = git@github.com:tonyOehme/scripts.git
[submodule ".config/nvim"]
	path = .config/nvim
	url = git@github.com:tonyOehme/nvim.git
[submodule ".config/alacritty/themes"]
	path = .config/alacritty/themes
	url = https://github.com/alacritty/alacritty-theme.git
[submodule ".oh-my-zsh/custom/plugins/zsh-syntax-highlighting"]
	path = .oh-my-zsh/custom/plugins/zsh-syntax-highlighting
	url = https://github.com/zsh-users/zsh-syntax-highlighting.git
